{
  "name": "@centlax/ui",
  "version": "0.0.14",
  "author": "Shimmy Rukundo",
  "description": "Centlax UI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/centlax/ui.git"
  },
  "homepage": "https://github.com/centlax/ui",
  "license": "MIT",
  "private": false,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=v16.20.2"
  },
  "scripts": {
    "build": "nuxt-module-build build",
    "prepack": "pnpm build",
    "play": "nuxi dev playground",
    "dev:play": "nuxi build playground",
    "dev:build": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "git": "bash scripts/git.sh",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
