{
  "name": "@centlax/ui",
  "type": "module",
  "version": "0.0.44",
  "main": "./nuxt.config.ts",
  "scripts": {
    "dev": "nuxi dev .playground node --max-old-space-size=4096",
    "build": "node scripts/types.cjs && nuxt build .playground",
    "dev:build": "nuxt build",
    "clean": "nuxt cleanup",
    "clean:play": "nuxt cleanup .playground",
    "generate": "nuxt generate .playground",
    "preview": "nuxt preview .playground",
    "git": "rm *.tgz || bash scripts/git.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "rm *.tgz || pnpm git && release-it && bash scripts/release.sh",
    "prepare": "nuxt prepare .playground"
  },
  "dependencies": {
    "@headlessui/tailwindcss": "^0.2.0",
    "@headlessui/vue": "^1.7.16",
    "@iconify-json/heroicons": "^1.1.19",
    "@nuxt/kit": "^3.9.0",
    "@nuxtjs/color-mode": "^3.3.2",
    "@nuxtjs/tailwindcss": "^6.10.1",
    "@popperjs/core": "^2.11.8",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@vueuse/core": "^10.7.0",
    "typescript": "^5.3.3",
    "defu": "^6.1.3",
    "fuse.js": "^6.6.2",
    "nuxt-icon": "^0.6.7",
    "ohash": "^1.1.3",
    "pathe": "^1.1.1",
    "scule": "^1.1.1",
    "tailwind-merge": "^2.2.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@nuxt/devtools": "^1.0.6",
    "@nuxt/eslint-config": "^0.2.0",
    "@nuxt/module-builder": "^0.5.4",
    "@nuxt/test-utils": "^3.9.0",
    "@release-it/conventional-changelog": "^8.0.1",
    "@vue/test-utils": "^2.4.3",
    "eslint": "^8.56.0",
    "happy-dom": "^12.10.3",
    "joi": "^17.11.0",
    "nuxt": "^3.9.0",
    "release-it": "^17.0.1",
    "unbuild": "^2.0.0",
    "valibot": "^0.21.0",
    "vitest-environment-nuxt": "^1.0.0",
    "vue-tsc": "^1.8.26",
    "yup": "^1.3.3",
    "zod": "^3.22.4"
  }
