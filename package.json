    "@vueuse/integrations": "^10.7.0",
    "@vueuse/math": "^10.7.0",
    "defu": "^6.1.3",
    "fuse.js": "^6.6.2",
    "nuxt-icon": "^0.6.7",
    "ohash": "^1.1.3",
    "pathe": "^1.1.1",
